# ArcheoQA — API Keys
# Copy this file to .env and fill in your keys

# OpenAI (for GPT-5 generator)
OPENAI_API_KEY=sk-...

# Google AI (for Gemini 3 Pro — OCR + vision enrichment)
GOOGLE_API_KEY=...

# Perplexity (for pplx-embed embeddings) — optional if using Qwen3 via another provider
PERPLEXITY_API_KEY=...

# Papers directory (default: ./data/papers)
PAPERS_DIR=./data/papers
