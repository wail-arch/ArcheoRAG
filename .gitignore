# ==============================
# ArcheoQA .gitignore
# ==============================
# Only push archeoqa/ folder (backend, frontend, data, .env.example)
# Everything else (PaperQA2 upstream) stays local only

# ------ IGNORE EVERYTHING at root by default ------
/*

# ------ KEEP these root files ------
!/.gitignore
!/README.md
!/LICENSE

# ------ KEEP the archeoqa project folder ------
!/archeoqa/

# ------ Python ------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
**/version.py

# ------ Environments ------
.env
.venv/
venv/

# ------ Data (keep structure, not content) ------
archeoqa/data/papers/*.pdf
archeoqa/data/docs_cache.pkl
archeoqa/data/settings.json

# ------ Node / Frontend ------
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*

# ------ IDE ------
.idea/
.vscode/

# ------ OS ------
.DS_Store
Thumbs.db
*.log
